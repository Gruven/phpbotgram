parameters:
    level: 9
    paths:
        - src
        - tests
        - tools/generator/src
    # The "(?)" suffix is PHPStan's "optional path" marker; it tells the analyser
    # the path may not yet exist on disk. tests/data is created on demand by
    # individual test cases. Phase 2 codegen will land its output under
    # src/Types/Generated/, src/Methods/Generated/, src/Enums/Generated/, which
    # the wildcards below will then exclude — until then Phase 1's hand-authored
    # stubs in src/Types/, src/Methods/, src/Enums/ stay analysed at level 9.
    excludePaths:
        - tests/data (?)
        - src/Types/Generated/*.php (?)
        - src/Methods/Generated/*.php (?)
        - src/Enums/Generated/*.php (?)
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
