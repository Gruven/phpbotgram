parameters:
    level: 9
    paths:
        - src
        - tests
        - tools/generator/src
    # The "(?)" suffix is PHPStan's "optional path" marker; it tells the analyser
    # the path may not yet exist on disk. tests/data is created on demand by
    # individual test cases; the generated src/Types/Methods/Enums directories
    # are populated in Phase 2 by the codegen pipeline.
    excludePaths:
        - tests/data (?)
        - src/Types/*.php
        - src/Methods/*.php
        - src/Enums/*.php
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
