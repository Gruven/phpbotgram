<?xml version="1.0" encoding="UTF-8"?>
<phpdocumentor
    configVersion="3"
    xmlns="https://www.phpdoc.org"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://www.phpdoc.org phpdoc.xsd">

    <title>phpbotgram API documentation</title>

    <paths>
        <output>build/docs/api</output>
        <cache>build/docs/.cache</cache>
    </paths>

    <version number="0.1.0">
        <api format="php">
            <source dsn=".">
                <path>src</path>
            </source>
            <ignore-tags>
                <ignore-tag>generated</ignore-tag>
            </ignore-tags>
            <output>.</output>
        </api>
    </version>
</phpdocumentor>
